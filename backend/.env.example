# Application
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=markethub
DB_PASSWORD=markethub_secret
DB_NAME=markethub

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1d

# Storage (s3-client-dtb - modo offline para desarrollo)
STORAGE_MODE=offline
STORAGE_ROOT_PATH=./uploads
STORAGE_MAX_FILE_SIZE=10mb
STORAGE_ALLOWED_MIME_TYPES=image/*,application/pdf

# Storage (s3-client-dtb - modo online para produccion)
# STORAGE_MODE=online
# STORAGE_BASE_URL=https://storage.example.com
# STORAGE_CLIENT_ID=markethub
# STORAGE_CLIENT_NAME=MarketHub
# STORAGE_PERMISSIONS=read,write,delete
# STORAGE_ALLOWED_PATHS=*
# STORAGE_CLIENT_SECRET=your-client-secret-min-32-chars
# STORAGE_TOTP_SECRET=your-totp-secret-min-16-chars
